<?xml version="1.0" encoding="UTF-8"?>
<componentSchema version="1.0">
  <meta>
    <productName>Barista Spotlight</productName>
    <documentType>Screen-by-Screen Component Schema</documentType>
    <purpose>
      Define each core screen at implementation level: layout zones, components, fields,
      actions, validation, events, and API/data bindings.
    </purpose>
    <scope>MVP-first with extension hooks</scope>
  </meta>

  <conventions>
    <layoutZones>
      <zone>topBar</zone>
      <zone>header</zone>
      <zone>body</zone>
      <zone>stickyFooter</zone>
      <zone>modal</zone>
      <zone>bottomSheet</zone>
      <zone>emptyState</zone>
      <zone>errorState</zone>
    </layoutZones>
    <componentTypes>
      <type>text</type>
      <type>button</type>
      <type>input</type>
      <type>textarea</type>
      <type>select</type>
      <type>multiSelect</type>
      <type>toggle</type>
      <type>tabBar</type>
      <type>card</type>
      <type>list</type>
      <type>media</type>
      <type>badge</type>
      <type>stat</type>
      <type>progress</type>
      <type>alert</type>
      <type>sheet</type>
      <type>modal</type>
      <type>chip</type>
      <type>carousel</type>
    </componentTypes>
    <apiMethodLegend>
      <method>GET</method>
      <method>POST</method>
      <method>PATCH</method>
      <method>DELETE</method>
    </apiMethodLegend>
  </conventions>

  <screens>

    <screen id="S2" name="Welcome / Entry">
      <layout>
        <topBar>
          <component id="S2-C1" type="text" name="BrandMark" />
        </topBar>
        <header>
          <component id="S2-C2" type="text" name="HeroHeadline" />
          <component id="S2-C3" type="text" name="HeroSubcopy" />
        </header>
        <body>
          <component id="S2-C4" type="button" name="SignUpButton" />
          <component id="S2-C5" type="button" name="LoginButton" />
          <component id="S2-C6" type="button" name="BrowseGuestButton" />
          <component id="S2-C7" type="card" name="ValueTeaserCards" />
        </body>
      </layout>
      <components>
        <component id="S2-C2">
          <props>
            <prop name="text">A global stage for baristas</prop>
          </props>
        </component>
        <component id="S2-C4">
          <props>
            <prop name="label">Create account</prop>
            <prop name="variant">primary</prop>
          </props>
          <actions>
            <action>navigate:S3</action>
          </actions>
        </component>
        <component id="S2-C5">
          <props>
            <prop name="label">Log in</prop>
            <prop name="variant">secondary</prop>
          </props>
          <actions>
            <action>navigate:S4</action>
          </actions>
        </component>
        <component id="S2-C6">
          <props>
            <prop name="label">Browse as guest</prop>
            <prop name="variant">ghost</prop>
          </props>
          <actions>
            <action>setSessionMode:guest</action>
            <action>navigate:S10</action>
          </actions>
        </component>
      </components>
    </screen>

    <screen id="S3" name="Create Account">
      <layout>
        <topBar>
          <component id="S3-C1" type="button" name="BackButton" />
          <component id="S3-C2" type="text" name="ScreenTitle" />
        </topBar>
        <body>
          <component id="S3-C3" type="input" name="EmailInput" />
          <component id="S3-C4" type="input" name="PasswordInput" />
          <component id="S3-C5" type="toggle" name="TermsCheckbox" />
          <component id="S3-C6" type="button" name="CreateAccountButton" />
          <component id="S3-C7" type="button" name="GoogleAuthButton" />
          <component id="S3-C8" type="alert" name="InlineError" />
        </body>
      </layout>
      <fields>
        <field name="email" componentId="S3-C3" type="email" required="true">
          <validation>
            <rule>must be valid email format</rule>
            <rule>max length 254</rule>
          </validation>
        </field>
        <field name="password" componentId="S3-C4" type="password" required="true">
          <validation>
            <rule>min length 8</rule>
            <rule>must contain at least 1 number or symbol</rule>
          </validation>
        </field>
        <field name="acceptedTerms" componentId="S3-C5" type="boolean" required="true" />
      </fields>
      <actions>
        <action id="S3-A1" trigger="tap:S3-C6">
          <behavior>submitForm</behavior>
          <apiBinding method="POST" endpoint="/auth/register">
            <requestBody>
              <param>email</param>
              <param>password</param>
              <param>acceptedTerms</param>
            </requestBody>
            <success>
              <event>auth.register.success</event>
              <navigate>S5</navigate>
            </success>
            <error>
              <event>auth.register.failed</event>
              <bindErrorTo>S3-C8</bindErrorTo>
            </error>
          </apiBinding>
        </action>
      </actions>
    </screen>

    <screen id="S4" name="Log In">
      <layout>
        <topBar>
          <component id="S4-C1" type="button" name="BackButton" />
          <component id="S4-C2" type="text" name="ScreenTitle" />
        </topBar>
        <body>
          <component id="S4-C3" type="input" name="EmailOrUsernameInput" />
          <component id="S4-C4" type="input" name="PasswordInput" />
          <component id="S4-C5" type="button" name="ForgotPasswordButton" />
          <component id="S4-C6" type="button" name="LoginButton" />
          <component id="S4-C7" type="alert" name="InlineError" />
        </body>
      </layout>
      <actions>
        <action id="S4-A1" trigger="tap:S4-C6">
          <apiBinding method="POST" endpoint="/auth/login">
            <requestBody>
              <param>identifier</param>
              <param>password</param>
            </requestBody>
            <success>
              <event>auth.login.success</event>
              <navigate>S10</navigate>
            </success>
            <error>
              <bindErrorTo>S4-C7</bindErrorTo>
            </error>
          </apiBinding>
        </action>
      </actions>
    </screen>

    <screen id="S5" name="Role Selection">
      <layout>
        <topBar>
          <component id="S5-C1" type="text" name="ScreenTitle" />
        </topBar>
        <body>
          <component id="S5-C2" type="card" name="BaristaRoleCard" />
          <component id="S5-C3" type="card" name="JudgeRoleCard" />
          <component id="S5-C4" type="card" name="HostRoleCard" />
          <component id="S5-C5" type="card" name="SponsorRoleCard" />
          <component id="S5-C6" type="card" name="AudienceRoleCard" />
        </body>
      </layout>
      <actions>
        <action trigger="tap:S5-C2">
          <apiBinding method="PATCH" endpoint="/users/me/role">
            <requestBody>
              <param name="role">barista</param>
            </requestBody>
            <success>
              <navigate>S6</navigate>
            </success>
          </apiBinding>
        </action>
        <action trigger="tap:S5-C3">
          <apiBinding method="PATCH" endpoint="/users/me/role">
            <requestBody>
              <param name="role">judge</param>
            </requestBody>
            <success>
              <navigate>S7</navigate>
            </success>
          </apiBinding>
        </action>
        <action trigger="tap:S5-C4">
          <apiBinding method="PATCH" endpoint="/users/me/role">
            <requestBody>
              <param name="role">host</param>
            </requestBody>
            <success>
              <navigate>S8</navigate>
            </success>
          </apiBinding>
        </action>
      </actions>
    </screen>

    <screen id="S6" name="Barista Onboarding">
      <layout>
        <topBar>
          <component id="S6-C1" type="progress" name="OnboardingProgress" />
        </topBar>
        <body>
          <component id="S6-C2" type="input" name="DisplayNameInput" />
          <component id="S6-C3" type="input" name="LocationInput" />
          <component id="S6-C4" type="input" name="CafeAffiliationInput" />
          <component id="S6-C5" type="multiSelect" name="SkillCategoriesSelect" />
          <component id="S6-C6" type="textarea" name="BioInput" />
          <component id="S6-C7" type="button" name="UploadProfilePhotoButton" />
        </body>
        <stickyFooter>
          <component id="S6-C8" type="button" name="CompleteOnboardingButton" />
        </stickyFooter>
      </layout>
      <fields>
        <field name="displayName" required="true">
          <validation>
            <rule>min 2 chars</rule>
            <rule>max 50 chars</rule>
          </validation>
        </field>
        <field name="location" required="false" />
        <field name="cafeAffiliation" required="false" />
        <field name="skills" required="true">
          <validation>
            <rule>at least 1 selected</rule>
          </validation>
        </field>
        <field name="bio" required="false">
          <validation>
            <rule>max 300 chars</rule>
          </validation>
        </field>
      </fields>
      <actions>
        <action trigger="tap:S6-C8">
          <apiBinding method="POST" endpoint="/profiles/barista">
            <requestBody>
              <param>displayName</param>
              <param>location</param>
              <param>cafeAffiliation</param>
              <param>skills</param>
              <param>bio</param>
              <param>profilePhotoAssetId</param>
            </requestBody>
            <success>
              <navigate>S10</navigate>
            </success>
          </apiBinding>
        </action>
      </actions>
    </screen>

    <screen id="S10" name="Home Feed">
      <dataSources>
        <source id="S10-D1" method="GET" endpoint="/feed/home" />
        <source id="S10-D2" method="GET" endpoint="/contests/featured" />
        <source id="S10-D3" method="GET" endpoint="/battles/live" />
      </dataSources>
      <layout>
        <topBar>
          <component id="S10-C1" type="text" name="BrandWordmark" />
          <component id="S10-C2" type="button" name="SearchButton" />
          <component id="S10-C3" type="button" name="NotificationsButton" />
        </topBar>
        <body>
          <component id="S10-C4" type="carousel" name="FeaturedContestCarousel" />
          <component id="S10-C5" type="list" name="LiveBattlesStrip" />
          <component id="S10-C6" type="tabBar" name="FeedModeTabs" />
          <component id="S10-C7" type="list" name="TrendingFeedList" />
          <component id="S10-C8" type="card" name="EditorialSpotlightCard" />
        </body>
      </layout>
      <bindings>
        <binding componentId="S10-C4" sourceId="S10-D2" path="items" />
        <binding componentId="S10-C5" sourceId="S10-D3" path="items" />
        <binding componentId="S10-C7" sourceId="S10-D1" path="feedItems" />
      </bindings>
      <actions>
        <action trigger="tap:S10-C2">
          <navigate>S17</navigate>
        </action>
        <action trigger="tap:S10-C3">
          <navigate>S18</navigate>
        </action>
        <action trigger="tap:item(S10-C4)">
          <navigate>S12</navigate>
          <routeParam name="contestId" source="item.id" />
        </action>
        <action trigger="tap:item(S10-C5)">
          <navigate>S14</navigate>
          <routeParam name="battleId" source="item.id" />
        </action>
        <action trigger="tap:item(S10-C7)">
          <conditional>
            <if>item.type == contest</if>
            <then navigate="S12" />
            <if>item.type == submission</if>
            <then navigate="S15" />
            <if>item.type == profile</if>
            <then navigate="S26" />
          </conditional>
        </action>
      </actions>
      <states>
        <emptyState>
          <title>No activity yet</title>
          <message>Follow baristas or explore contests to build your feed.</message>
        </emptyState>
        <errorState>
          <message>Could not load feed.</message>
          <retryAction>reload:S10-D1,S10-D2,S10-D3</retryAction>
        </errorState>
      </states>
    </screen>

    <screen id="S11" name="Contest Index">
      <dataSources>
        <source id="S11-D1" method="GET" endpoint="/contests" />
      </dataSources>
      <layout>
        <topBar>
          <component id="S11-C1" type="text" name="ScreenTitle" />
          <component id="S11-C2" type="button" name="FilterButton" />
        </topBar>
        <body>
          <component id="S11-C3" type="tabBar" name="ContestStatusTabs" />
          <component id="S11-C4" type="list" name="ContestCardList" />
        </body>
      </layout>
      <queryParams>
        <param name="status" sourceComponentId="S11-C3" />
        <param name="category" source="filterSheet.category" />
        <param name="region" source="filterSheet.region" />
      </queryParams>
      <actions>
        <action trigger="tap:S11-C2">
          <openBottomSheet>S54</openBottomSheet>
        </action>
        <action trigger="tap:item(S11-C4)">
          <navigate>S12</navigate>
          <routeParam name="contestId" source="item.id" />
        </action>
      </actions>
    </screen>

    <screen id="S12" name="Contest Detail">
      <dataSources>
        <source id="S12-D1" method="GET" endpoint="/contests/{contestId}" />
        <source id="S12-D2" method="GET" endpoint="/contests/{contestId}/entries/preview" />
      </dataSources>
      <layout>
        <topBar>
          <component id="S12-C1" type="button" name="BackButton" />
          <component id="S12-C2" type="button" name="ShareButton" />
        </topBar>
        <header>
          <component id="S12-C3" type="card" name="ContestHeroCard" />
        </header>
        <body>
          <component id="S12-C4" type="card" name="TimelineCard" />
          <component id="S12-C5" type="card" name="ScoringSummaryCard" />
          <component id="S12-C6" type="card" name="PrizeCard" />
          <component id="S12-C7" type="list" name="HostAndSponsorCards" />
          <component id="S12-C8" type="list" name="EntryPreviewList" />
        </body>
        <stickyFooter>
          <component id="S12-C9" type="button" name="EnterContestButton" />
        </stickyFooter>
      </layout>
      <actions>
        <action trigger="tap:S12-C5">
          <navigate>S13</navigate>
        </action>
        <action trigger="tap:S12-C9">
          <conditional>
            <if>user.role == guest</if>
            <then navigate="S3" />
            <if>contest.isEligible == true</if>
            <then navigate="S19" />
            <else>
              <showMessage>You are not eligible for this contest.</showMessage>
            </else>
          </conditional>
        </action>
      </actions>
    </screen>

    <screen id="S14" name="Battle Viewer">
      <dataSources>
        <source id="S14-D1" method="GET" endpoint="/battles/{battleId}" />
      </dataSources>
      <layout>
        <topBar>
          <component id="S14-C1" type="text" name="BattleHeader" />
          <component id="S14-C2" type="progress" name="BattleProgress" />
        </topBar>
        <body>
          <component id="S14-C3" type="media" name="LeftEntryMedia" />
          <component id="S14-C4" type="media" name="RightEntryMedia" />
        </body>
        <stickyFooter>
          <component id="S14-C5" type="button" name="VoteLeftButton" />
          <component id="S14-C6" type="button" name="SkipButton" />
          <component id="S14-C7" type="button" name="VoteRightButton" />
        </stickyFooter>
      </layout>
      <actions>
        <action trigger="tap:S14-C5">
          <apiBinding method="POST" endpoint="/battles/{battleId}/vote">
            <requestBody>
              <param name="selection">left</param>
            </requestBody>
            <success>
              <event>battle.vote.success</event>
              <navigate>S16</navigate>
            </success>
          </apiBinding>
        </action>
        <action trigger="tap:S14-C7">
          <apiBinding method="POST" endpoint="/battles/{battleId}/vote">
            <requestBody>
              <param name="selection">right</param>
            </requestBody>
            <success>
              <event>battle.vote.success</event>
              <navigate>S16</navigate>
            </success>
          </apiBinding>
        </action>
        <action trigger="tap:S14-C3">
          <navigate>S15</navigate>
          <routeParam name="submissionId" source="leftSubmission.id" />
        </action>
        <action trigger="tap:S14-C4">
          <navigate>S15</navigate>
          <routeParam name="submissionId" source="rightSubmission.id" />
        </action>
      </actions>
    </screen>

    <screen id="S15" name="Submission Detail">
      <dataSources>
        <source id="S15-D1" method="GET" endpoint="/submissions/{submissionId}" />
      </dataSources>
      <layout>
        <topBar>
          <component id="S15-C1" type="button" name="BackButton" />
          <component id="S15-C2" type="button" name="ShareButton" />
          <component id="S15-C3" type="button" name="ReportButton" />
        </topBar>
        <header>
          <component id="S15-C4" type="media" name="SubmissionMediaPlayer" />
        </header>
        <body>
          <component id="S15-C5" type="card" name="BaristaSummaryCard" />
          <component id="S15-C6" type="stat" name="ScoreSummary" />
          <component id="S15-C7" type="card" name="MetadataCard" />
          <component id="S15-C8" type="list" name="JudgeCommentsList" />
        </body>
      </layout>
      <actions>
        <action trigger="tap:S15-C5">
          <navigate>S26</navigate>
          <routeParam name="profileId" source="submission.profileId" />
        </action>
        <action trigger="tap:S15-C3">
          <apiBinding method="POST" endpoint="/reports">
            <requestBody>
              <param name="targetType">submission</param>
              <param name="targetId" source="submissionId" />
            </requestBody>
          </apiBinding>
        </action>
      </actions>
    </screen>

    <screen id="S16" name="Contest Results">
      <dataSources>
        <source id="S16-D1" method="GET" endpoint="/contests/{contestId}/results" />
      </dataSources>
      <layout>
        <header>
          <component id="S16-C1" type="card" name="WinnerHeroCard" />
        </header>
        <body>
          <component id="S16-C2" type="list" name="PlacementList" />
          <component id="S16-C3" type="card" name="ScoreBreakdownCard" />
          <component id="S16-C4" type="button" name="ShareResultsButton" />
        </body>
      </layout>
      <actions>
        <action trigger="tap:item(S16-C2)">
          <navigate>S26</navigate>
          <routeParam name="profileId" source="item.profileId" />
        </action>
      </actions>
    </screen>

    <screen id="S17" name="Search">
      <layout>
        <topBar>
          <component id="S17-C1" type="input" name="SearchInput" />
        </topBar>
        <body>
          <component id="S17-C2" type="tabBar" name="SearchTypeTabs" />
          <component id="S17-C3" type="list" name="SearchResultsList" />
        </body>
      </layout>
      <actions>
        <action trigger="change:S17-C1">
          <apiBinding method="GET" endpoint="/search">
            <queryParams>
              <param name="q" sourceComponentId="S17-C1" />
              <param name="type" sourceComponentId="S17-C2" />
            </queryParams>
            <success>
              <bindTo>S17-C3</bindTo>
            </success>
          </apiBinding>
        </action>
      </actions>
    </screen>

    <screen id="S18" name="Notifications Center">
      <dataSources>
        <source id="S18-D1" method="GET" endpoint="/notifications" />
      </dataSources>
      <layout>
        <topBar>
          <component id="S18-C1" type="text" name="ScreenTitle" />
          <component id="S18-C2" type="button" name="MarkAllReadButton" />
        </topBar>
        <body>
          <component id="S18-C3" type="list" name="NotificationList" />
        </body>
      </layout>
      <actions>
        <action trigger="tap:S18-C2">
          <apiBinding method="POST" endpoint="/notifications/mark-all-read" />
        </action>
        <action trigger="tap:item(S18-C3)">
          <conditional>
            <if>item.linkType == contest</if>
            <then navigate="S12" />
            <if>item.linkType == profile</if>
            <then navigate="S26" />
            <if>item.linkType == opportunity</if>
            <then navigate="S39" />
          </conditional>
        </action>
      </actions>
    </screen>

    <screen id="S19" name="Create / Submit Entry Hub">
      <dataSources>
        <source id="S19-D1" method="GET" endpoint="/contests/eligible" />
        <source id="S19-D2" method="GET" endpoint="/submissions/drafts" />
      </dataSources>
      <layout>
        <body>
          <component id="S19-C1" type="list" name="EligibleContestList" />
          <component id="S19-C2" type="list" name="DraftSubmissionList" />
        </body>
      </layout>
      <actions>
        <action trigger="tap:item(S19-C1)">
          <navigate>S20</navigate>
          <routeParam name="contestId" source="item.id" />
        </action>
        <action trigger="tap:item(S19-C2)">
          <navigate>S23</navigate>
          <routeParam name="draftId" source="item.id" />
        </action>
      </actions>
    </screen>

    <screen id="S20" name="Submission Setup">
      <dataSources>
        <source id="S20-D1" method="GET" endpoint="/contests/{contestId}/submission-requirements" />
      </dataSources>
      <layout>
        <body>
          <component id="S20-C1" type="card" name="RequirementChecklist" />
          <component id="S20-C2" type="button" name="RecordInAppButton" />
          <component id="S20-C3" type="button" name="UploadFromLibraryButton" />
        </body>
      </layout>
      <actions>
        <action trigger="tap:S20-C2">
          <navigate>S21</navigate>
          <routeParam name="contestId" source="contestId" />
        </action>
        <action trigger="tap:S20-C3">
          <navigate>S22</navigate>
          <routeParam name="contestId" source="contestId" />
        </action>
      </actions>
    </screen>

    <screen id="S21" name="In-App Camera / Recording">
      <layout>
        <body>
          <component id="S21-C1" type="media" name="CameraPreview" />
          <component id="S21-C2" type="progress" name="DurationMeter" />
        </body>
        <stickyFooter>
          <component id="S21-C3" type="button" name="RecordToggleButton" />
          <component id="S21-C4" type="button" name="UseClipButton" />
        </stickyFooter>
      </layout>
      <actions>
        <action trigger="tap:S21-C4">
          <navigate>S23</navigate>
          <routeParam name="tempMediaAssetId" source="capturedAsset.id" />
        </action>
      </actions>
    </screen>

    <screen id="S22" name="Media Upload">
      <layout>
        <body>
          <component id="S22-C1" type="button" name="SelectFileButton" />
          <component id="S22-C2" type="progress" name="UploadProgressBar" />
          <component id="S22-C3" type="alert" name="UploadErrorAlert" />
        </body>
      </layout>
      <actions>
        <action trigger="tap:S22-C1">
          <apiBinding method="POST" endpoint="/media/upload">
            <requestBody>
              <param name="file">devicePickerSelection</param>
            </requestBody>
            <success>
              <navigate>S23</navigate>
              <routeParam name="tempMediaAssetId" source="response.assetId" />
            </success>
            <error>
              <bindErrorTo>S22-C3</bindErrorTo>
            </error>
          </apiBinding>
        </action>
      </actions>
    </screen>

    <screen id="S23" name="Submission Review and Metadata">
      <layout>
        <header>
          <component id="S23-C1" type="media" name="ClipPreviewPlayer" />
        </header>
        <body>

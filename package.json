{
  "name": "barista-spotlight",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "bun run --hot src/index.tsx",
    "dev:client": "cd client && bun run dev",
    "dev:all": "bun run dev & cd client && bun run dev",
    "build": "cd client && bun install && bun run build",
    "start": "bun run src/index.tsx",
    "build:server": "bun build src/index.tsx --outdir=dist",
    "migrate": "bun run src/db/database.ts",
    "seed": "bun run src/db/seed.ts",
    "test": "bun test",
    "typecheck": "bunx tsc --noEmit && cd client && bunx tsc --noEmit"
  },
  "dependencies": {
    "hono": "^4"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.9.3"
  }
}
